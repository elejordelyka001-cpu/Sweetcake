<%- include('../partials/header') %>
<div class="page-header">
  <div>
    <h1 class="page-title"><%= customer ? 'Edit Customer' : 'Add Customer' %></h1>
  </div>
  <a href="/customers" class="btn btn-outline">← Back</a>
</div>
<div class="form-layout">
  <form method="POST" action="/customers<%= customer ? '/' + customer.id : '' %>" class="card">
    <div class="form-group">
      <label>Full Name *</label>
      <input type="text" name="name" class="form-control" required value="<%= customer ? customer.name : '' %>" />
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="form-control" value="<%= customer ? customer.email || '' : '' %>" />
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" class="form-control" value="<%= customer ? customer.phone || '' : '' %>" />
      </div>
    </div>
    <div class="form-group">
      <label>Address</label>
      <textarea name="address" class="form-control" rows="2"><%= customer ? customer.address || '' : '' %></textarea>
    </div>
    <div class="form-group">
      <label>Notes</label>
      <textarea name="notes" class="form-control" rows="2" placeholder="Allergies, preferences..."><%= customer ? customer.notes || '' : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= customer ? 'Save Changes' : 'Add Customer' %></button>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
