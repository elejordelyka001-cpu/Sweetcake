<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — SweetBake</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="login-body">
<div class="login-wrapper">
  <div class="login-art">
    <div class="login-art-content">
      <div class="art-icon">🍰</div>
      <h1 class="art-title">SweetBake</h1>
      <p class="art-sub">Cake Shop Management System</p>
      <div class="art-dots">
        <span></span><span></span><span></span>
      </div>
    </div>
  </div>
  <div class="login-form-panel">
    <div class="login-form-inner">
      <h2 class="login-heading">Welcome back</h2>
      <p class="login-sub">Sign in to your bakery dashboard</p>
      <% if (flash) { %>
        <div class="flash flash-<%= flash.type %>">
          <span><%= flash.msg %></span>
        </div>
      <% } %>
      <form method="POST" action="/login" class="auth-form">
        <div class="form-group">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" required placeholder="admin@sweetbake.com" />
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="••••••••" />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Sign In</button>
      </form>
      <p class="login-hint">Default: admin@sweetbake.com / admin123</p>
    </div>
  </div>
</div>
</body>
</html>
